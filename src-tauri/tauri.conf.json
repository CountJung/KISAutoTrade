{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KISAutoTrade",
  "version": "0.1.2",
  "identifier": "com.countjung.kisautotrade",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KISAutoTrade",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null,
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Korean"],
        "installMode": "perMachine"
      },
      "wix": null
    },
    "shortDescription": "개인용 자동 주식 매매 시스템"
  }
}
