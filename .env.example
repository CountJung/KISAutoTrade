# 환경변수 예시 - 실제 값은 .env 파일에 작성 (gitignore)
# 권장: secure_config.json 파일 사용 (secure_config.example.json 참고)
VITE_API_URL=http://localhost:1420

# ── KIS 실전투자 API 키 ────────────────────────────────────────
KIS_APP_KEY=your_real_app_key_here
KIS_APP_SECRET=your_real_app_secret_here
KIS_ACCOUNT_NO=12345678-01

# ── 투자 모드 (기본값: false = 실전투자) ──────────────────────
# true 로 설정하면 모의투자 모드 (모의투자 전용 키가 있어야 함)
KIS_IS_PAPER_TRADING=false
